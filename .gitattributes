# Default: auto-detect text files and normalize line endings to LF in the repo
* text=auto eol=lf

# Explicit text files (LF in repo, native on checkout)
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.css text eol=lf
*.html text eol=lf

# Binary files (do not touch)
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.svg binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary